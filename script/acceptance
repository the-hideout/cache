#!/usr/bin/env bash

set -euo pipefail

source script/env "$@"

HTTP_PORT="${CACHE_ACCEPTANCE_PORT:-8080}"
BASE_URL="${CACHE_ACCEPTANCE_BASE_URL:-http://localhost:${HTTP_PORT}}"
MAX_TTL_SECONDS="9223372036"

failures=0
tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT

section() {
  echo -e "\n${PURPLE}=== $* ===${OFF}"
}

pass() {
  echo -e "${GREEN}PASS${OFF} $*"
}

fail() {
  failures=$((failures + 1))
  echo -e "${RED}FAIL${OFF} $*"
}

curl_request() {
  local method="$1"
  local path="$2"
  local body="${3-}"
  local content_type="${4:-application/json}"
  local headers_file="${tmp_dir}/headers"
  local body_file="${tmp_dir}/body"
  local err_file="${tmp_dir}/curl.err"
  local status
  local url

  url="${BASE_URL}${path}"
  rm -f "$headers_file" "$body_file" "$err_file"

  local args=(
    --insecure
    --location
    --silent
    --show-error
    --request "$method"
    --dump-header "$headers_file"
    --output "$body_file"
    --write-out "%{http_code}"
  )

  if [[ "$#" -ge 3 ]]; then
    args+=(--header "Content-Type: ${content_type}" --data-raw "$body")
  fi

  args+=("$url")

  if ! status="$(curl "${args[@]}" 2>"$err_file")"; then
    status="000"
  fi

  RESPONSE_STATUS="$status"
  RESPONSE_BODY=""
  RESPONSE_HEADERS=""
  RESPONSE_ERROR=""

  if [[ -f "$body_file" ]]; then
    RESPONSE_BODY="$(<"$body_file")"
  fi
  if [[ -f "$headers_file" ]]; then
    RESPONSE_HEADERS="$(<"$headers_file")"
  fi
  if [[ -s "$err_file" ]]; then
    RESPONSE_ERROR="$(<"$err_file")"
  fi
}

response_header() {
  local header_name="$1"
  local lower_name

  lower_name="$(printf '%s' "$header_name" | tr '[:upper:]' '[:lower:]')"
  printf '%s\n' "$RESPONSE_HEADERS" | awk -v key="$lower_name" '
    {
      line = tolower($0)
      if (index(line, key ":") == 1) {
        sub(/\r$/, "")
        sub(/^[^:]*:[[:space:]]*/, "")
        print
        exit
      }
    }
  '
}

expect_request() {
  local name="$1"
  local method="$2"
  local path="$3"
  local want_status="$4"
  local want_body="${5-}"
  local body="${6-}"

  if [[ "$#" -ge 6 ]]; then
    curl_request "$method" "$path" "$body"
  else
    curl_request "$method" "$path"
  fi

  if [[ "$RESPONSE_STATUS" != "$want_status" ]]; then
    fail "$name status: expected ${want_status}, got ${RESPONSE_STATUS}; body=${RESPONSE_BODY}; error=${RESPONSE_ERROR}"
    return
  fi

  if [[ "$#" -ge 5 && "$RESPONSE_BODY" != "$want_body" ]]; then
    fail "$name body: expected ${want_body}, got ${RESPONSE_BODY}"
    return
  fi

  pass "$name"
}

expect_json_error() {
  local name="$1"
  local method="$2"
  local path="$3"
  local want_status="$4"
  local want_error="$5"
  local body="${6-}"

  if [[ "$#" -ge 6 ]]; then
    curl_request "$method" "$path" "$body"
  else
    curl_request "$method" "$path"
  fi

  if [[ "$RESPONSE_STATUS" != "$want_status" ]]; then
    fail "$name status: expected ${want_status}, got ${RESPONSE_STATUS}; body=${RESPONSE_BODY}; error=${RESPONSE_ERROR}"
    return
  fi

  if [[ "$RESPONSE_BODY" != *"\"error\":\"${want_error}\""* ]]; then
    fail "$name error body: expected error ${want_error}, got ${RESPONSE_BODY}"
    return
  fi

  if [[ "$(response_header Cache-Control)" != "no-store" ]]; then
    fail "$name Cache-Control: expected no-store, got $(response_header Cache-Control)"
    return
  fi

  pass "$name"
}

expect_cache_hit() {
  local name="$1"
  local key="$2"
  local want_body="$3"
  local min_ttl="$4"
  local max_ttl="$5"
  local ttl

  curl_request GET "/api/cache?key=${key}"

  if [[ "$RESPONSE_STATUS" != "200" ]]; then
    fail "$name status: expected 200, got ${RESPONSE_STATUS}; body=${RESPONSE_BODY}"
    return
  fi

  if [[ "$RESPONSE_BODY" != "$want_body" ]]; then
    fail "$name body: expected ${want_body}, got ${RESPONSE_BODY}"
    return
  fi

  ttl="$(response_header X-CACHE-TTL)"
  if [[ ! "$ttl" =~ ^[0-9]+$ || "$ttl" -lt "$min_ttl" || "$ttl" -gt "$max_ttl" ]]; then
    fail "$name X-CACHE-TTL: expected ${min_ttl}-${max_ttl}, got ${ttl}"
    return
  fi

  if [[ "$(response_header Cache-Control)" != "public, max-age=${ttl}" ]]; then
    fail "$name Cache-Control: expected public, max-age=${ttl}, got $(response_header Cache-Control)"
    return
  fi

  if [[ "$(response_header Content-Type)" != application/json* ]]; then
    fail "$name Content-Type: expected application/json, got $(response_header Content-Type)"
    return
  fi

  pass "$name"
}

post_cache() {
  local name="$1"
  local payload="$2"

  expect_request "$name" POST "/api/cache" "200" '{"message":"cached"}' "$payload"
}

wait_for_cache() {
  local attempt

  section "Startup"
  for attempt in {1..120}; do
    curl_request GET "/health"
    if [[ "$RESPONSE_STATUS" == "200" && "$RESPONSE_BODY" == "OK" ]]; then
      pass "cache server became healthy"
      return
    fi
    sleep 1
  done

  fail "cache server did not become healthy within 120 seconds"
  docker compose logs cache || true
}

section "Compose"
cd "$DIR"
make run
wait_for_cache

section "Health"
expect_request "/health" GET "/health" "200" "OK"
expect_request "/api/health" GET "/api/health" "200" "OK"
expect_request "POST /health returns 404" POST "/health" "404"
if [[ "$(response_header Cache-Control)" != "no-store" ]]; then
  fail "POST /health Cache-Control: expected no-store, got $(response_header Cache-Control)"
else
  pass "POST /health no-store"
fi

section "Cache GET Validation"
expect_json_error "GET /api/cache without key" GET "/api/cache" "400" "key query parameter is required"
expect_json_error "GET /api/cache with empty key" GET "/api/cache?key=" "400" "key query parameter is required"
expect_json_error "GET missing key" GET "/api/cache?key=missing" "404" "key not found"
expect_json_error "GET uses first key parameter" GET "/api/cache?key=missing&key=defaultttlkey" "404" "key not found"
expect_request "PUT /api/cache returns 404" PUT "/api/cache" "404"
if [[ "$(response_header Cache-Control)" != "no-store" ]]; then
  fail "PUT /api/cache Cache-Control: expected no-store, got $(response_header Cache-Control)"
else
  pass "PUT /api/cache no-store"
fi
expect_request "DELETE /api/cache returns 404" DELETE "/api/cache" "404"
if [[ "$(response_header Cache-Control)" != "no-store" ]]; then
  fail "DELETE /api/cache Cache-Control: expected no-store, got $(response_header Cache-Control)"
else
  pass "DELETE /api/cache no-store"
fi

section "Cache POST Validation"
expect_json_error "POST without body" POST "/api/cache" "400" "invalid request body"
expect_json_error "POST invalid JSON" POST "/api/cache" "400" "invalid request body" "not json"
expect_json_error "POST missing key" POST "/api/cache" "400" "invalid request body" '{"value":"test"}'
expect_json_error "POST missing value" POST "/api/cache" "400" "invalid request body" '{"key":"test"}'
expect_json_error "POST empty key" POST "/api/cache" "400" "invalid request body" '{"key":"","value":"test"}'
expect_json_error "POST empty value" POST "/api/cache" "400" "invalid request body" '{"key":"test","value":""}'
expect_json_error "POST invalid TTL" POST "/api/cache" "400" "ttl must be a string representation of an integer" '{"key":"badttl","value":"test","ttl":"not_a_number"}'
expect_json_error "POST fractional TTL" POST "/api/cache" "400" "ttl must be a string representation of an integer" '{"key":"fracttl","value":"test","ttl":"30.5"}'
expect_json_error "POST numeric TTL" POST "/api/cache" "400" "invalid request body" '{"key":"numericttl","value":"test","ttl":30}'
expect_json_error "POST negative TTL" POST "/api/cache" "400" "ttl must be greater than zero" '{"key":"negttl","value":"test","ttl":"-1"}'
expect_json_error "POST zero TTL" POST "/api/cache" "400" "ttl must be greater than zero" '{"key":"zerottl","value":"test","ttl":"0"}'
expect_json_error "POST overflow TTL" POST "/api/cache" "400" "ttl must not exceed ${MAX_TTL_SECONDS} seconds" "{\"key\":\"overflowttl\",\"value\":\"test\",\"ttl\":\"$((MAX_TTL_SECONDS + 1))\"}"

section "Cache Round Trips"
post_cache "POST default TTL" '{"key":"defaultttlkey","value":"default ttl response"}'
expect_cache_hit "GET default TTL" "defaultttlkey" '"default ttl response"' 450 500

post_cache "POST custom TTL" '{"key":"customttlkey","value":"custom ttl response","ttl":"60"}'
expect_cache_hit "GET custom TTL" "customttlkey" '"custom ttl response"' 1 60

post_cache "POST overwrite existing key" '{"key":"customttlkey","value":"overwritten response","ttl":"120"}'
expect_cache_hit "GET overwritten key" "customttlkey" '"overwritten response"' 1 120

post_cache "POST leading-zero TTL" '{"key":"leadingzerottl","value":"leading zero ttl","ttl":"0030"}'
expect_cache_hit "GET leading-zero TTL" "leadingzerottl" '"leading zero ttl"' 1 30

section "Special Keys And Values"
post_cache "POST JSON string value" '{"key":"jsonvalue","value":"{\"nested\":\"json\"}","ttl":"30"}'
expect_cache_hit "GET JSON string value" "jsonvalue" '"{\"nested\":\"json\"}"' 1 30

post_cache "POST spaced key" '{"key":"key with spaces","value":"spaced key value","ttl":"30"}'
expect_cache_hit "GET spaced key" "key%20with%20spaces" '"spaced key value"' 1 30

post_cache "POST unicode key/value" '{"key":"unicode🚀","value":"Hello 世界! 🎉","ttl":"30"}'
expect_cache_hit "GET unicode key/value" "unicode%F0%9F%9A%80" '"Hello 世界! 🎉"' 1 30

post_cache "POST Redis command name as key" '{"key":"SET","value":"redis command as key","ttl":"30"}'
expect_cache_hit "GET Redis command name as key" "SET" '"redis command as key"' 1 30

post_cache "POST punctuation-heavy key" '{"key":"key:with.dots-and_symbols","value":"punctuation key","ttl":"30"}'
expect_cache_hit "GET punctuation-heavy key" "key%3Awith.dots-and_symbols" '"punctuation key"' 1 30

post_cache "POST escaped value" '{"key":"escaped","value":"Line 1\nLine 2\tTabbed\r\nWindows","ttl":"30"}'
expect_cache_hit "GET escaped value" "escaped" '"Line 1\nLine 2\tTabbed\r\nWindows"' 1 30

section "Expiration"
post_cache "POST short TTL" '{"key":"shortttlkey","value":"short ttl","ttl":"1"}'
expect_cache_hit "GET short TTL immediately" "shortttlkey" '"short ttl"' 1 1
sleep 2
expect_json_error "GET expired key" GET "/api/cache?key=shortttlkey" "404" "key not found"

section "Light Concurrency"
concurrency_failed=0
pids=()
for i in {1..20}; do
  curl --insecure --location --silent --show-error --request POST "${BASE_URL}/api/cache" --header 'Content-Type: application/json' --data-raw "{\"key\":\"concurrent${i}\",\"value\":\"value ${i}\",\"ttl\":\"60\"}" --output /dev/null &
  pids+=("$!")
done
for pid in "${pids[@]}"; do
  if ! wait "$pid"; then
    concurrency_failed=1
  fi
done
if [[ "$concurrency_failed" -eq 0 ]]; then
  pass "concurrent POST requests completed"
else
  fail "one or more concurrent POST requests failed"
fi

concurrency_verify_failed=0
for i in {1..20}; do
  curl_request GET "/api/cache?key=concurrent${i}"
  if [[ "$RESPONSE_STATUS" != "200" || "$RESPONSE_BODY" != "\"value ${i}\"" ]]; then
    fail "concurrent key ${i}: expected value ${i}, got status=${RESPONSE_STATUS} body=${RESPONSE_BODY}"
    concurrency_verify_failed=1
  fi
done
if [[ "$concurrency_verify_failed" -eq 0 ]]; then
  pass "concurrent values verified"
fi

section "Results"
if [[ "$failures" -eq 0 ]]; then
  echo -e "${GREEN}all acceptance tests passed${OFF}"
  exit 0
fi

echo -e "${RED}${failures} acceptance assertion(s) failed${OFF}"
exit 1
