#!/usr/bin/env bash

set -euo pipefail

source script/env "$@"

echo -e "${BLUE}Checking Go formatting...${OFF}"
cd "$CACHE_GO_DIR"
unformatted="$(gofmt -l main.go main_test.go)"
if [[ -n "$unformatted" ]]; then
  echo -e "${RED}❌ Go files need formatting:${OFF}"
  echo "$unformatted"
  exit 1
fi

echo -e "${BLUE}Checking GitHub Actions pins...${OFF}"
cd "$DIR"
unpinned=0
while IFS= read -r line; do
  if [[ ! "$line" =~ @[0-9a-f]{40}([[:space:]]|$) ]]; then
    echo "$line"
    unpinned=1
  fi
done < <(grep -R -nE 'uses:[[:space:]]*[^ @]+@' .github/workflows || true)

if [[ "$unpinned" -ne 0 ]]; then
  echo -e "${RED}❌ Found GitHub Actions not pinned to full commit SHAs${OFF}"
  exit 1
fi

echo -e "${GREEN}✅ Lint checks passed${OFF}"
